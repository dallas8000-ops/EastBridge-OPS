DEBUG=True
SECRET_KEY=change-me-in-production
# Local dev (no Docker): leave empty → SQLite at backend/db.sqlite3
# Docker Compose: postgres://eastbridge:eastbridge@db:5432/eastbridge
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
DEFAULT_FROM_EMAIL=alerts@eastbridge.local
ALERT_WEBHOOK_URL=

# Embeddings: auto | fastembed | openai | hash
# openai requires a real key from https://platform.openai.com/api-keys
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Assistant answers: auto | openai | template
ANSWER_PROVIDER=auto
OPENAI_CHAT_MODEL=gpt-4o-mini

# Local dev — npm run dev sets VITE_API_PROXY automatically
# VITE_API_PROXY=http://127.0.0.1:8888

# --- Production (see DEPLOY.md or DEPLOY-RAILWAY.md) ---
# DEBUG=False
# SECRET_KEY=generate-a-long-random-secret
# ALLOWED_HOSTS=eastbridge.gilliomfrontlinedigital.com
# CSRF_TRUSTED_ORIGINS=https://eastbridge.gilliomfrontlinedigital.com
# CORS_ALLOWED_ORIGINS=https://eastbridge.gilliomfrontlinedigital.com

# --- Gilliom Railway (see DEPLOY-RAILWAY.md) ---
# CUSTOM_DOMAIN=eastbridge.gilliomfrontlinedigital.com
# DATABASE_URL=<linked from Railway Postgres>
# EMBEDDING_PROVIDER=openai
# ANSWER_PROVIDER=openai
# SEED_ON_DEPLOY=false
