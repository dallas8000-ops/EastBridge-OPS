# Gilliom production — Railway web service variables
# Copy values into Railway Variables (or push via Deployment-Stripe-center vault + deploy prep)

DEBUG=False
SECRET_KEY=
CUSTOM_DOMAIN=eastbridge.gilliomfrontlinedigital.com

# Linked from Railway PostgreSQL plugin
DATABASE_URL=

OPENAI_API_KEY=
EMBEDDING_PROVIDER=openai
ANSWER_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4o-mini

# One-time first deploy
SEED_ON_DEPLOY=false

# Auto-set by Railway — do not hardcode
# RAILWAY_PUBLIC_DOMAIN=eastbridge-ops-production.up.railway.app
# RAILWAY_ENVIRONMENT=production
# PORT=8080
